# Supabase 配置
# 复制此文件为 .env 并填入你的 Supabase 凭证

# Supabase 项目 URL
# 格式: https://xxxxxxxxxxxxx.supabase.co
COZE_SUPABASE_URL=https://your-project.supabase.co

# Supabase 匿名密钥（anon public key）
# 在 Supabase 控制台的 Settings -> API 中获取
COZE_SUPABASE_ANON_KEY=your-anon-key-here

# 对象存储配置（可选，用于头像上传）
COZE_BUCKET_ENDPOINT_URL=https://your-bucket-endpoint.com
COZE_BUCKET_NAME=your-bucket-name
