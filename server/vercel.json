{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/vercel.js"
    }
  ],
  "env": {
    "COZE_SUPABASE_URL": "@coze-supabase-url",
    "COZE_SUPABASE_ANON_KEY": "@coze-supabase-anon-key",
    "NODE_ENV": "production"
  }
}
