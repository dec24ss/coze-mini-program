      "timeout": 60,
      "memorySize": 256,
      "handler": "index.main",
      "runtime": "Nodejs16.13"
    },
    {
      "name": "getRankList",
      "timeout": 60,
      "memorySize": 256,
      "handler": "index.main",
      "runtime": "Nodejs16.13"
    },
    {
      "name": "addPoints",
      "timeout": 60,
      "memorySize": 256,
      "handler": "index.main",
      "runtime": "Nodejs16.13"
    },
    {
      "name": "consumePoints",
      "timeout": 60,
      "memorySize": 256,
