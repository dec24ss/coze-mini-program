{
  "version": 2,
  "buildCommand": "pnpm build:server",
  "outputDirectory": "server/dist",
  "installCommand": "pnpm install --filter server",
  "builds": [
    {
      "src": "server/package.json",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "server/dist/main.js"
    }
  ],
  "functions": {
    "server/dist/main.js": {
      "runtime": "nodejs20.x",
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "env": {
    "COZE_SUPABASE_URL": "@coze-supabase-url",
    "COZE_SUPABASE_ANON_KEY": "@coze-supabase-anon-key"
  }
}
