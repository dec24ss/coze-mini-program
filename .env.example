# 前端环境变量配置示例
# 复制此文件为 .env.local 并填入你的配置

# 项目域名（后端API地址）
# 本地开发：http://localhost:3000
# 生产环境：https://your-server.com（需要配置为你的后端服务器地址）
PROJECT_DOMAIN=http://localhost:3000

# 微信小程序 AppID（可选，用于自动上传）
# TARO_APP_WEAPP_APPID=your-wechat-appid

# ==========================================
# 后端环境变量配置（server/.env）
# ==========================================

# Supabase 配置示例
# 复制此部分到 server/.env 文件

# Supabase 项目 URL
# 格式: https://xxxxxxxxxxxxx.supabase.co
COZE_SUPABASE_URL=https://your-project.supabase.co

# Supabase 匿名密钥（anon public key）
# 在 Supabase 控制台的 Settings -> API 中获取
COZE_SUPABASE_ANON_KEY=your-anon-key-here

# 对象存储配置（可选，用于头像上传）
COZE_BUCKET_ENDPOINT_URL=
COZE_BUCKET_NAME=
